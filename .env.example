# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key-here

# Server admin key - used to protect mutating API routes (set in Render/Vercel)
ADMIN_API_KEY=choose-a-strong-secret

# Frontend API base (deployed server URL)
VITE_API_BASE=https://wernerburger.onrender.com

# (Optional) Other envs
# NODE_ENV=production
# PORT=4000
